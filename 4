class Vehiculo:
    def __init__(self, marca, modelo, anio):
        self.marca = marca
        self.modelo = modelo
        self.anio = anio
    
    def imprimir_detalles(self):
        print(f"Marca: {self.marca}")
        print(f"Modelo: {self.modelo}")
        print(f"Año: {self.anio}")

class Automovil(Vehiculo):
    def __init__(self, marca, modelo, anio, kmPorLitro):
        super().__init__(marca, modelo, anio)
        self.kmPorLitro = kmPorLitro
    
    def calcular_eficiencia(self):
        return self.kmPorLitro
    
    def proyectar_combustible(self, distancia):
        return distancia / self.kmPorLitro
    
    def imprimir_detalles(self):
        super().imprimir_detalles()
        print(f"Eficiencia: {self.calcular_eficiencia()} km/litro")

class Motocicleta(Vehiculo):
    def __init__(self, marca, modelo, anio, kmPorLitro):
        super().__init__(marca, modelo, anio)
        self.kmPorLitro = kmPorLitro
    
    def calcular_eficiencia(self):
        return self.kmPorLitro
    
    def proyectar_combustible(self, distancia):
        return distancia / self.kmPorLitro
    
    def imprimir_detalles(self):
        super().imprimir_detalles()
        print(f"Eficiencia: {self.calcular_eficiencia()} km/litro")

if __name__ == "__main__":
    auto = Automovil("Toyota", "Corolla", 2022, 15)
    auto.imprimir_detalles()
    distancia = 300
    print(f"Combustible necesario para {distancia} km: {auto.proyectar_combustible(distancia):.2f} litros")
    print()

    moto = Motocicleta("Honda", "CB500", 2021, 25)
    moto.imprimir_detalles()
    print(f"Combustible necesario para {distancia} km: {moto.proyectar_combustible(distancia):.2f} litros")
